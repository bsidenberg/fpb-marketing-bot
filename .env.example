# ============================================================
# FPB Marketing Bot — required environment variables
# Copy to .env.local for local development.
# Set all of these in Vercel project settings for production.
# Never commit .env.local or real secret values.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # bypasses RLS; server-only
VITE_SUPABASE_URL=https://<ref>.supabase.co    # same URL, exposed to Vite build
VITE_SUPABASE_ANON_KEY=<anon-key>              # safe for client reads only

# ── Execution security ────────────────────────────────────────────────────────
# These secrets gate server-only endpoints. When a secret is unset:
#   • production (NODE_ENV=production): the endpoint FAILS CLOSED with HTTP 503
#   • non-production: the endpoint warns in logs and allows the request (dev)
EXECUTE_SECRET=<random-32-char-hex>            # guards /api/execute-action and campaign creation endpoints
IMAGE_PROCESS_SECRET=<random-32-char-hex>      # guards /api/image-process (sent as x-image-process-secret header)
# VITE_EXECUTE_SECRET — intentionally removed as of Safety Sprint 2; do not set

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of browser origins allowed to call the API. If unset,
# defaults to the production Vercel URL + localhost dev servers (plus Vercel
# preview deployments of this project). When set explicitly, the value is the
# exact authoritative list — preview deployments are NOT auto-allowed.
ALLOWED_ORIGINS=https://fpb-marketing-bot.vercel.app,http://localhost:5173

# ── Lead ingestion ────────────────────────────────────────────────────────────
# REQUIRED in two places — must match exactly:
#   1. This Vercel project (set below)
#   2. FPB website: Gravity Forms webhook header + CallRail webhook secret header
#      Header name: x-leads-ingest-secret
# Rotate both at the same time. Redeploy Vercel after changing.
LEADS_INGEST_SECRET=<random-32-char-hex>

# ── Attribution ───────────────────────────────────────────────────────────────
OUTCOME_WINDOW_DAYS=7                          # optional; measurement window in days (default 7)
CRON_SECRET=<random-32-char-hex>               # bearer token for manual cron triggers

# ── Multi-account cron mode (Stage B1) ───────────────────────────────────────
# Default false — only FPB processed by /api/cron-analyze and /api/evaluate-outcomes.
# Set to 'true' to enable cron loop over ALL active accounts.
# Recommended: leave false until Stage B2 dashboard verifies multi-account UX.
ENABLE_MULTI_ACCOUNT_CRON=false

# ── Google Ads ────────────────────────────────────────────────────────────────
GOOGLE_ADS_CLIENT_ID=<oauth2-client-id>
GOOGLE_ADS_CLIENT_SECRET=<oauth2-client-secret>
GOOGLE_ADS_REFRESH_TOKEN=<long-lived-refresh-token>
GOOGLE_ADS_DEVELOPER_TOKEN=<developer-token>
GOOGLE_ADS_CUSTOMER_ID=<customer-account-id>
GOOGLE_ADS_MANAGER_ID=<mcc-manager-id>        # optional; only if using a manager account

# ── Meta / Facebook ───────────────────────────────────────────────────────────
META_ACCESS_TOKEN=<long-lived-system-user-token>   # never a short-lived user token
META_AD_ACCOUNT_ID=<ad-account-id>                 # with or without act_ prefix
META_PAGE_ID=<facebook-page-id>

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<anthropic-api-key>
